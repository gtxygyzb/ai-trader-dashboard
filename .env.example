# AI API 配置 - 示例文件
# 复制为 .env，填入真实 key 后即可使用
# .env 已被 .gitignore 排除，不会被提交到 git

# 套餐 key（优先使用）
SUBSCRIPTION_KEY=sk-cp-YOUR_SUBSCRIPTION_KEY_HERE

# 按量 key（套餐失败时回落，可选）
PAY_AS_YOU_GO_KEY=sk-api-YOUR_PAY_AS_YOU_GO_KEY_HERE

# 可选：自定义 API 入口和模型
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# ANTHROPIC_MODEL=MiniMax-M3
